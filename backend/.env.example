# Copy to `.env` and adjust. Loaded by dotenvy in development.
# `nix run .#db` boots a local Postgres matching this URL (trust auth, no password).
DATABASE_URL=postgres://postgres@localhost:5432/ev_backend
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info,backend=debug

# Sentry error tracking (optional — disabled when unset)
SENTRY_DSN=
APP_ENV=development

# TigerBeetle (financial ledger)
# `nix run .#tb` boots a local TigerBeetle matching this address.
TIGERBEETLE_ADDRESS=127.0.0.1:3001
TIGERBEETLE_CLUSTER_ID=0
